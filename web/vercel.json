{
  "version": 2,
  "headers": [
    {
      "source": "/(.*\\.wasm)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" },
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/ages-of-aether.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ]
}
